# term4k: ignore build outputs, package artifacts, and local IDE/runtime noise.

### C/C++ build outputs ###
*.d
*.slo
*.lo
*.o
*.obj
*.gch
*.pch
*.so
*.dylib
*.dll
*.mod
*.smod
*.lai
*.la
*.a
*.lib
*.exe
*.out
*.app

### CMake / CPack generated files (repo root) ###
/build/
/cmake-build-*/
/CMakeCache.txt
/CMakeFiles/
/CMakeScripts/
/CTestTestfile.cmake
/Testing/
/cmake_install.cmake
/install_manifest*.txt
/Makefile
/compile_commands.json
/CPackConfig.cmake
/CPackSourceConfig.cmake
/_CPack_Packages/
/_deps/
/.cmake-deps/
/CMakeUserPresets.json
/CMakeLists.txt.user

### Package artifacts ###
*.deb
*.rpm
*.tar.gz

### Test / coverage / profiling ###
/coverage/
*.gcno
*.gcda
*.gcov
*.profraw
*.profdata

### JetBrains / CLion local files ###
# Default deny for .idea; allowlist only stable, team-shared config.
.idea/*
!.idea/.gitignore
!.idea/vcs.xml
!.idea/codeStyles/
!.idea/codeStyles/*.xml

*.iws
out/
.idea_modules/

### Logs / crash dumps ###
*.log
*.pid
core
core.*

### OS / editor temp files ###
*~
.fuse_hidden*
.directory
.Trash-*
.nfs*
.DS_Store
Thumbs.db
*.swp
*.swo
.vscode/

### Python / script runtime artifacts ###
__pycache__/
*.py[cod]
.python-version
.pytest_cache/
.mypy_cache/
.ruff_cache/

### Local scratch / ad-hoc debug files ###
.tmp_*
